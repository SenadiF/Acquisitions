{
  "name": "acquisitions",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#config/*": "./src/config/*",
    "#models/*": "./src/models/*",
    "#controllers/*": "./src/controllers/*",
    "#utils/*": "./src/utils/*",
    "#middleware/*": "./src/middleware/*",
    "#services/*": "./src/services/*",
    "#validations/*": "./src/validations/*",
    "#routers/*": "./src/routers/*"
  },
  "scripts": {
  "dev": "node --watch src/index.js",
  "start": "node src/index.js",
  "lint": "eslint .",
  "lint:fix": "eslint . --fix",
  "format": "prettier --write .",
  "format:check": "prettier --check .",

  "db:generate": "npx drizzle-kit generate",
  "db:migrate": "npx drizzle-kit push",
  "db:studio": "npx drizzle-kit studio",

  "dev:docker": "bash ./scripts/dev.sh",
  "prod:docker": "bash ./scripts/prod.sh"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SenadiF/Acquisitions.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SenadiF/Acquisitions/issues"
  },
  "homepage": "https://github.com/SenadiF/Acquisitions#readme",
  "dependencies": {
    "@arcjet/inspect": "^1.3.0",
    "@arcjet/node": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1"
  }
}
